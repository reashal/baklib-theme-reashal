<article class="article-container">
  <section class="moments">
    <h1>动态管理</h1>

    {% assign has_moments = false %}
    {% for p in site.pages reversed %}
      {% if p.settings.date != blank %}{% assign has_moments = true %}{% endif %}
    {% endfor %}
    {% if has_moments %}
      {% for p in site.pages reversed %}
        {% if p.settings.date != blank %}
      <article class="moment" id="{{ p.hashid | default: p.id }}">
        <header class="moment-author">
          <div class="author-info">
            <span class="author-name">睿屿青衫</span>
            <time class="author-date" datetime="{{ p.settings.date }}">{{ p.settings.date }}</time>
          </div>
        </header>
        <section class="moment-content">
          {% assign moment_content = p.settings.content | default: p.content %}
          {% if moment_content != blank %}
            {% assign moment_content = moment_content | replace: '<div bke-role="paragraph">', '<p>' | replace: '</div>', '</p>' %}
            {{ moment_content }}
          {% else %}
            <a href="{{ p.full_path }}">{{ p.link_text }}</a>
          {% endif %}
        </section>
        {% if p.settings.comments != blank %}
          <section class="moment-interaction">
            {% assign comment_list = p.settings.comments | newline_to_br | strip_newlines | split: "<br />" %}
            <div class="interaction-comments">
              {% for comment in comment_list %}{% assign c = comment | strip %}{% if c != blank %}<p class="comment-item"><span class="comment-author">睿屿青衫:</span><span class="comment-text">{{ c }}</span></p>{% endif %}{% endfor %}
            </div>
          </section>
        {% endif %}
      </article>
        {% endif %}
      {% endfor %}
    {% else %}
      <p style="text-align:center;color:#999;padding:2rem;">暂无动态</p>
    {% endif %}

    {% if current_user.present? %}
    <section class="moment-publish" style="margin-top:2rem;padding:1.5rem;border:1px solid var(--color-border,#ddd);border-radius:8px;">
      <h2 style="margin:0 0 1rem 0;font-size:1.1rem;">发布新动态</h2>

      {% form_tag 'page' %}
        <input type="hidden" name="page[template_name]" value="moment" />
        <input type="hidden" name="page[template_style]" value="" />
        <input type="hidden" name="page[parent_full_path]" value="/" />
        <input type="hidden" name="page[published]" value="true" />
        <input type="hidden" name="page[name]" value="动态" />
        <input type="hidden" name="return_template_name" value="index" />

        <div style="display:flex;flex-direction:column;gap:0.6rem;">
          <input name="page[template_variables][date]" type="text" placeholder="发表日期（如 2026.07.16）" required
                 style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;" />

          {% assign moment_content = page.settings.content %}
          <div>
            <label style="display:block;margin-bottom:0.25rem;font-size:0.85rem;">正文内容</label>
            {% form_field_tag 'richtext', 'page[template_variables][content]', moment_content, toolbar: 'simple' %}
          </div>

          <div>
            <label style="display:block;margin-bottom:0.25rem;font-size:0.85rem;">动态图片（每行：URL|alt）</label>
            <textarea name="page[template_variables][images]" rows="2" placeholder="可选"
                      style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;resize:vertical;">{{ page.settings.images }}</textarea>
          </div>

          <input name="page[template_variables][location]" type="text" placeholder="位置（可选）"
                 value="{{ page.settings.location }}"
                 style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;" />
          <input name="page[template_variables][stars]" type="text" placeholder="点赞（逗号分隔，可选）"
                 value="{{ page.settings.stars }}"
                 style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;" />

          <div>
            <label style="display:block;margin-bottom:0.25rem;font-size:0.85rem;">动态评论（每行一条）</label>
            <textarea name="page[template_variables][comments]" rows="2" placeholder="可选"
                      style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;resize:vertical;">{{ page.settings.comments }}</textarea>
          </div>

          <button type="submit" style="padding:0.6rem 1.5rem;background:var(--color-primary,#00787d);color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:0.95rem;">
            发布动态
          </button>
        </div>
      {% endform_tag %}

      {% if errors %}
        <div style="margin-top:0.75rem;color:red;font-size:0.9rem;">
          {% for error in errors %}
            <p>{{ error }}</p>
          {% endfor %}
        </div>
      {% endif %}
    </section>
    {% else %}
    <p style="text-align:center;color:#999;padding:1rem;font-size:0.9rem;">登录后可在此发布动态</p>
    {% endif %}

    <footer class="moments-footer">
      <p class="end-tip">故事暂且讲到这里</p>
    </footer>
  </section>
</article>
