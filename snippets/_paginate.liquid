{% assign p = paginate %}
<nav class="docs-pagination" aria-label="分页导航">
  {% if p.prev_page %}
    <a href="{{ p.url_for[p.prev_page] }}" class="page-btn page-prev" data-turbo-action="replace">‹</a>
  {% else %}
    <span class="page-btn page-prev" disabled>‹</span>
  {% endif %}

  {% for part in p.series %}
    {% if part == 'gap' %}
      <span class="page-sep">…</span>
    {% elsif part == p.current_page %}
      <span class="page-btn page-active">{{ part }}</span>
    {% else %}
      <a href="{{ p.url_for[part] }}" class="page-btn" data-turbo-action="replace">{{ part }}</a>
    {% endif %}
  {% endfor %}

  {% if p.next_page %}
    <a href="{{ p.url_for[p.next_page] }}" class="page-btn page-next" data-turbo-action="replace">›</a>
  {% else %}
    <span class="page-btn page-next" disabled>›</span>
  {% endif %}
</nav>
