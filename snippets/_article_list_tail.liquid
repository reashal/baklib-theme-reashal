<footer class="docs-footer" id="docs-footer">
  <nav class="docs-pagination" id="docs-pagination" aria-label="分页导航"></nav>
  <p class="end-tip" id="docs-end-tip" style="display:none;">故事暂且讲到这里</p>
</footer>
<script>
  (function() {
    var container = document.getElementById("docs-container");
    var pagination = document.getElementById("docs-pagination");
    var footer = document.getElementById("docs-footer");
    var endTip = document.getElementById("docs-end-tip");
    if (!container) return;

    var allItems = Array.from(container.querySelectorAll(".docs-body"));
    if (allItems.length === 0) return;

    var currentPage = 0;
    var perPage = 1;
    var hasEnoughSpace = false;

    function calcPerPage() {
      var rootStyle = getComputedStyle(document.documentElement);
      var perPage = parseInt(rootStyle.getPropertyValue('--per-page')) || 1;
      return perPage;
    }

    function totalPages() {
      if (perPage <= 0) return 0;
      return Math.ceil(allItems.length / perPage);
    }

    function checkEnoughSpace() {
      var mainEl = document.querySelector(".main");
      if (!mainEl) { hasEnoughSpace = false; return; }

      var footerEl = document.getElementById("docs-footer");
      if (!footerEl) { hasEnoughSpace = false; return; }

      var viewportH = mainEl.clientHeight;
      var footerH = footerEl.offsetHeight;
      var articleStyle = getComputedStyle(container);
      var articlePaddingV = parseFloat(articleStyle.paddingTop) + parseFloat(articleStyle.paddingBottom);

      var usedHeight = articlePaddingV;
      allItems.forEach(function(item) {
        var itemStyle = getComputedStyle(item);
        usedHeight += item.offsetHeight + parseFloat(itemStyle.marginTop) + parseFloat(itemStyle.marginBottom);
      });

      var available = viewportH - usedHeight - footerH;
      hasEnoughSpace = available > 100;
    }

    function showPage(page) {
      currentPage = Math.max(0, Math.min(page, totalPages() - 1));
      var start = currentPage * perPage;
      var end = start + perPage;
      var isLastPage = currentPage === totalPages() - 1;

      checkEnoughSpace();
      endTip.style.display = (totalPages() === 1 && hasEnoughSpace) ? "" : "none";

      allItems.forEach(function(item, i) {
        var isVisible = i >= start && i < end;
        item.style.display = isVisible ? "" : "none";
        if (isVisible && i === end - 1) {
          item.classList.add("docs-last");
        } else {
          item.classList.remove("docs-last");
        }
      });

      renderPagination();
    }

    function renderPagination() {
      var total = totalPages();
      if (total <= 1) { pagination.style.display = "none"; return; }
      pagination.style.display = "";

      var pages = [];
      if (total <= 7) {
        for (var i = 0; i < total; i++) pages.push(i);
      } else {
        pages.push(0);
        if (currentPage > 3) pages.push("…");
        var lo = Math.max(1, currentPage - 1);
        var hi = Math.min(total - 2, currentPage + 1);
        for (var i = lo; i <= hi; i++) pages.push(i);
        if (currentPage < total - 4) pages.push("…");
        pages.push(total - 1);
      }

      pagination.innerHTML = "";

      var prev = document.createElement("button");
      prev.className = "page-btn page-prev";
      prev.textContent = "‹";
      prev.disabled = currentPage === 0;
      prev.addEventListener("click", function() { showPage(currentPage - 1); scrollToTop(); });
      pagination.appendChild(prev);

      pages.forEach(function(p) {
        if (p === "…") {
          var sep = document.createElement("span");
          sep.className = "page-sep";
          sep.textContent = "…";
          pagination.appendChild(sep);
        } else {
          var btn = document.createElement("button");
          btn.className = "page-btn" + (p === currentPage ? " page-active" : "");
          btn.textContent = String(Number(p) + 1);
          btn.addEventListener("click", function() { showPage(Number(p)); scrollToTop(); });
          pagination.appendChild(btn);
        }
      });

      var next = document.createElement("button");
      next.className = "page-btn page-next";
      next.textContent = "›";
      next.disabled = currentPage === totalPages() - 1;
      next.addEventListener("click", function() { showPage(currentPage + 1); scrollToTop(); });
      pagination.appendChild(next);
    }

    function scrollToTop() {
      var mainEl = document.querySelector(".main");
      if (mainEl) mainEl.scrollTo({ top: 0, behavior: "smooth" });
    }

    function init() {
      perPage = calcPerPage();
      checkEnoughSpace();
      showPage(0);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      requestAnimationFrame(function() { requestAnimationFrame(init); });
    }

    var resizeTimer;
    window.addEventListener("resize", function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        var prevPage = currentPage;
        perPage = calcPerPage();
        checkEnoughSpace();
        showPage(Math.min(prevPage, totalPages() - 1));
      }, 150);
    });
  })();
</script>
