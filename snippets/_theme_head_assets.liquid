<script>
  (function() {
    var theme = null;
    try {
      var saved = localStorage.getItem('theme');
      var savedAt = parseInt(localStorage.getItem('themeTs') || '0', 10);
      if (saved && Date.now() - savedAt < 21600000) theme = saved;
    } catch (error) {}
    if (!theme) {
      var hour = new Date().getHours();
      theme = hour > 20 || hour < 6 || window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    document.documentElement.classList.toggle('dark', theme === 'dark');
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>

<style>
  @font-face {
    font-family: "HM";
