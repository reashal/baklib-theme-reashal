  }
  @font-face {
    font-family: "iconfont";
    src: url("{% render 'cdn_asset_url', path: 'fonts/iconfont.woff2' %}") format("woff2"),
      url("{% render 'cdn_asset_url', path: 'fonts/iconfont.woff' %}") format("woff"),
      url("{% render 'cdn_asset_url', path: 'fonts/iconfont.ttf' %}") format("truetype");
