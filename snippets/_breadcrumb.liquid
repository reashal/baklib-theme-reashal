{% comment %}
  @params breadcrumb — array of { link_text, path }
{% endcomment %}

{% assign crumbs_size = breadcrumb | size %}
{% if crumbs_size > 0 %}
  <div class="page-breadcrumb-subnav print:hidden">
    <div class="page-container">
      <nav class="features-subnav-scroll page-breadcrumb-subnav__inner" aria-label="{{ 'generic.breadcrumb_nav' | t }}">
        {% for crumb in breadcrumb %}
          {% if forloop.index0 == 0 %}
            {% assign crumb_label = 'generic.home' | t %}
          {% else %}
            {% assign crumb_label = crumb.link_text %}
          {% endif %}
          {% if forloop.last %}
            <span class="index-tab-btn index-tab-btn--active shrink-0 whitespace-nowrap" aria-current="page">
              {{ crumb_label }}
            </span>
          {% else %}
            <a href="{{ crumb.path }}" class="index-tab-btn shrink-0 whitespace-nowrap">
              {{ crumb_label }}
            </a>
          {% endif %}
          {% unless forloop.last %}
            <span class="shrink-0 text-base-content/50" aria-hidden="true">/</span>
          {% endunless %}
        {% endfor %}
      </nav>
    </div>
  </div>
{% endif %}
