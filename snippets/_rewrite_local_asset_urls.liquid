{%- assign asset_paths = local_asset_paths | newline_to_br | strip_newlines | split: '<br />' -%}
{%- for raw_path in asset_paths -%}
  {%- assign asset_path = raw_path | strip -%}
  {%- if asset_path != blank -%}
    {%- capture resolved_url -%}{%- render 'cdn_asset_url', path: asset_path -%}{%- endcapture -%}
    {%- assign resolved_url = resolved_url | strip -%}
    {%- if format == 'json' -%}
      {%- capture source_with_slash -%}"/{{ asset_path }}"{%- endcapture -%}
      {%- capture source_without_slash -%}"{{ asset_path }}"{%- endcapture -%}
      {%- capture replacement -%}"{{ resolved_url }}"{%- endcapture -%}
      {%- assign rewritten_content = rewritten_content | replace: source_with_slash, replacement | replace: source_without_slash, replacement -%}
    {%- else -%}
      {%- capture double_with_slash -%}src="/{{ asset_path }}"{%- endcapture -%}
      {%- capture double_without_slash -%}src="{{ asset_path }}"{%- endcapture -%}
      {%- capture single_with_slash -%}src='/{{ asset_path }}'{%- endcapture -%}
      {%- capture single_without_slash -%}src='{{ asset_path }}'{%- endcapture -%}
      {%- capture double_replacement -%}src="{{ resolved_url }}"{%- endcapture -%}
      {%- capture single_replacement -%}src='{{ resolved_url }}'{%- endcapture -%}
      {%- assign rewritten_content = rewritten_content | replace: double_with_slash, double_replacement | replace: double_without_slash, double_replacement | replace: single_with_slash, single_replacement | replace: single_without_slash, single_replacement -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{{- rewritten_content -}}
