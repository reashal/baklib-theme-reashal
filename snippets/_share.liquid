<div class="share-container">
    <button class="share-btn" id="share-btn" aria-label="分享文章">
        <span>分享</span>
    </button>
</div>
<div class="share-overlay" id="share-overlay">
    <div class="share-card" id="share-card">
        <div class="share-card-header">
            <div class="share-card-banner" style="background-image:var(--wallpaper)"></div>
        </div>
        <div class="share-card-content">
            <h3 class="share-card-title" id="share-card-title"></h3>
            <p class="share-card-desc" id="share-card-desc"></p>
            <div class="share-card-link">
                <input type="text" id="share-link-input" readonly />
                <button id="copy-btn" class="copy-btn"><span>复制链接</span></button>
            </div>
            <div class="share-card-qrcode">
                <canvas id="qrcode-canvas"></canvas>
                <p class="qrcode-tip">扫码访问</p>
            </div>
        </div>
    </div>
</div>
<script>
(function(){
  var shareBtn=document.getElementById('share-btn');
  var overlay=document.getElementById('share-overlay');
  var shareCard=document.getElementById('share-card');
  var copyBtn=document.getElementById('copy-btn');
  var titleEl=document.getElementById('share-card-title');
  var descEl=document.getElementById('share-card-desc');
  var inputEl=document.getElementById('share-link-input');
  var currentTitle='', currentUrl='', currentDescription='';
  shareBtn.addEventListener('click',function(){
    currentUrl=window.location.href;
    currentTitle=document.title.split('｜')[0].trim();
    var metaDescription=document.querySelector('meta[name="description"]');currentDescription=metaDescription?metaDescription.getAttribute('content'):'';
    titleEl.textContent=currentTitle;
    descEl.textContent=currentDescription;
    descEl.style.display=currentDescription?'block':'none';
    inputEl.value=currentUrl;
    overlay.classList.add('show');
    generateQRCode();
  });
  overlay.addEventListener('click',function(e){if(e.target===overlay)overlay.classList.remove('show');});
  copyBtn.addEventListener('click',function(){
    inputEl.select();
    var text='我从『睿屿青衫』为您分享了一篇文章～\n标题：'+currentTitle+'\n摘要：'+(currentDescription||'暂无摘要')+'\n链接：'+currentUrl;
    navigator.clipboard.writeText(text).then(function(){alert('已复制到剪贴板');}).catch(function(){alert('复制失败，请手动复制链接');});
  });
  function generateQRCode(){
    var canvas=document.getElementById('qrcode-canvas');
    var ctx=canvas.getContext('2d');
    var size=150;
    canvas.width=size;canvas.height=size;
    if(typeof qrcode==='undefined'){loadQRCodeLibrary();return;}
    try{
      var qr=qrcode(0,'M');
      qr.addData(currentUrl);
      qr.make();
      ctx.fillStyle='#ffffff';ctx.fillRect(0,0,size,size);
      var moduleCount=qr.getModuleCount();
      var moduleSize=size/moduleCount;
      ctx.fillStyle='#000000';
      for(var row=0;row<moduleCount;row++){for(var col=0;col<moduleCount;col++){if(qr.isDark(row,col)){ctx.fillRect(col*moduleSize,row*moduleSize,moduleSize,moduleSize);}}}
    }catch(e){drawFallbackQRCode();}
  }
  function loadQRCodeLibrary(){
    var script=document.createElement('script');
    script.src='https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js';
    script.onload=function(){generateQRCode();};
    script.onerror=function(){drawFallbackQRCode();};
    document.head.appendChild(script);
  }
  function drawFallbackQRCode(){
    var canvas=document.getElementById('qrcode-canvas');
    var ctx=canvas.getContext('2d');
    var size=150;
    canvas.width=size;canvas.height=size;
    ctx.fillStyle='#ffffff';ctx.fillRect(0,0,size,size);
    ctx.fillStyle='#000000';ctx.font='12px Arial';ctx.textAlign='center';
    ctx.fillText('二维码生成失败',size/2,size/2);
  }
})();
</script>
