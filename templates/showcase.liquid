{% schema %}
{
  "label": "展示",
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "页面描述",
      "default": ""
    }
  ]
}
{% endschema %}

<article class="article-container showcase">
  <nav class="showcase-nav">
    {% assign sorted_sections = page.children | order_by: 'published_at' | limit: 100 %}
    {% for section in sorted_sections %}
      {% assign section_icon = 'icon-pc' %}
      {% if section.path contains '/links' %}{% assign section_icon = 'icon-plane' %}{% endif %}
      <a href="{{ section.path }}">
        <i class="iconfont {{ section_icon }}"></i>
        <span>{{ section.link_text }}</span>
      </a>
    {% endfor %}
  </nav>

  <h2 class="showcase-h">展示</h2>
  {% if page.settings.description != blank %}
    <p class="showcase-p">{{ page.settings.description }}</p>
  {% endif %}

  <div class="showcase-body">
    {% for section in sorted_sections %}
      <a href="{{ section.path }}" class="showcase-app-card">
        <div class="showcase-info">
          <h3>{{ section.link_text }}</h3>
          {% if section.settings.description != blank %}
            <p>{{ section.settings.description }}</p>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</article>
