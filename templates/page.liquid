

{% assign is_moment = false %}
{% assign _path_parts = page.path | split: "/" %}
{% assign moment_slug_prefix = page.slug | slice: 0, 2 %}
{% if _path_parts.size == 2 and moment_slug_prefix == 'm-' and page.settings.date != blank %}
  {% assign is_moment = true %}
{% endif %}
{% assign is_section = false %}
{% if page.path == "/docs" %}
  {% assign is_section = true %}
{% endif %}
{% if page.path == "/showcase" %}
  {% assign is_section = true %}
{% endif %}

{% if is_section %}
  {% comment %}--- Article listing mode (category, via site.pages) ---{% endcomment %}
  {% assign prefix = page.path | append: "/" %}
  <article class="article-container docs" id="docs-container">
    {% assign found = false %}
    {% assign sorted = site.pages | order_by: '-created_at' %}
    {% for item in sorted %}
      {% if item.path != page.path and item.path contains prefix and item.settings.pinned %}
        {% assign found = true %}
        <div class="docs-body docs-fixed">
          <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
          <p class="docs-p">{{ item.settings.description }}</p>
          <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
        </div>
      {% endif %}
    {% endfor %}
    {% for item in sorted %}
      {% if item.path != page.path and item.path contains prefix %}
        {% unless item.settings.pinned %}
          {% assign found = true %}
          <div class="docs-body">
            <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
            <p class="docs-p">{{ item.settings.description }}</p>
            <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
          </div>
        {% endunless %}
      {% endif %}
    {% endfor %}
    {% unless found %}
      <div class="docs-body"><p class="docs-p">暂无文章</p></div>
    {% endunless %}
    {% render 'article_list_tail' %}
  </article>
{% elsif page.children.size > 0 %}
  {% comment %}--- Article listing mode (via page.children) ---{% endcomment %}
  {% assign sorted = page.children | sort: "published_at" | reverse %}
  <article class="article-container docs" id="docs-container">
    {% for item in sorted %}
      {% if item.settings.pinned %}
        <div class="docs-body docs-fixed">
          <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
          <p class="docs-p">{{ item.settings.description }}</p>
          <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
        </div>
      {% endif %}
    {% endfor %}
    {% for item in sorted %}
      {% unless item.settings.pinned %}
        <div class="docs-body">
          <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
          <p class="docs-p">{{ item.settings.description }}</p>
          <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
        </div>
      {% endunless %}
    {% endfor %}
    {% render 'article_list_tail' %}
  </article>
{% elsif is_moment %}
  {% comment %}--- Moment pages live on the homepage ---{% endcomment %}
  {% assign moment_id = page.hashid | default: page.id %}
  <article class="article-container doc">
    <p>该动态已在首页展示，正在跳转。</p>
    <p><a href="/#{{ moment_id }}">返回首页动态</a></p>
  </article>
  <script>
    window.location.replace('/#{{ moment_id }}');
  </script>
{% else %}
  {% comment %}--- Standard article detail mode ---{% endcomment %}
  <article class="article-container doc">
    <h1>{{ page.settings.title | default: page.link_text }}</h1>
    {% assign doc_content = page.settings.content | default: page.content %}
    {% render 'rewrite_local_asset_urls', content: doc_content, format: 'html' %}
    {% assign article_tags = page.settings.tags | default: page.tags %}
    {% if article_tags != blank %}
      <section class="article-tags">
        {% for tag in article_tags %}
          <span class="tag">{{ tag.name }}</span>
        {% endfor %}
      </section>
    {% elsif page.seo_keywords != blank %}
      {% assign kw_tags = page.seo_keywords | split: ", " %}
      <section class="article-tags">
        {% for kw in kw_tags %}
          <span class="tag">{{ kw }}</span>
        {% endfor %}
      </section>
    {% endif %}
    <section class="article-copy">
      <div>本文作者：<a href="https://www.reashal.com{{ page.path }}" target="_blank" rel="noopener noreferrer">睿屿青衫</a></div>
      <div>本文来源：<a href="https://www.reashal.com{{ page.path }}" target="_blank" rel="noopener noreferrer">https://www.reashal.com{{ page.path }}</a></div>
      <div class="article-copy-info">许可协议：<a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0</a></div>
      <div class="article-copy-info">本站随笔均为原创，涉及隐私且时效性较强，不允许任何人以任何形式转载。</div>
      <div class="article-copy-info">本站笔记多对原始作品作出修改，允许非商业用途转载，转载时请注明出处。</div>
    </section>
    {% render 'giscus' %}
  </article>
{% endif %}

{% schema %}
  {
    "name": "页面",
    "description": "标准页面（自动判断列表/详情/动态模式）",
    "settings": [
      { "id": "title", "type": "text", "label": "页面标题" },
      { "id": "pinned", "type": "checkbox", "label": "置顶文章", "default": false, "info": "开启后该文章将在列表最前显示" },
      { "id": "description", "type": "textarea", "label": "页面描述" },
      { "id": "date", "type": "text", "label": "发表日期", "queryable": true },
      { "id": "images", "type": "textarea", "label": "动态图片（每行：URL|alt）" },
      { "id": "location", "type": "text", "label": "动态位置" },
      { "id": "stars", "type": "text", "label": "动态点赞（逗号分隔）" },
      { "id": "comments", "type": "textarea", "label": "动态评论（每行一条）" },
      { "id": "content", "type": "richtext", "label": "正文内容" },
      { "id": "tags", "type": "tag_picker", "multiple": true, "label": "标签" }
    ]
  }
{% endschema %}
