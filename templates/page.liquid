

{% assign is_moment = false %}
{% assign _path_parts = page.path | split: "/" %}
{% if _path_parts.size == 2 and _path_parts[1] != "" and page.settings.date != blank and page.settings.description == blank %}
  {% assign is_moment = true %}
{% endif %}
{% assign is_section = false %}
{% if page.path == "/docs" %}
  {% assign is_section = true %}
{% endif %}
{% if page.path == "/showcase" %}
  {% assign is_section = true %}
{% endif %}

{% if is_section %}
  {% comment %}--- Article listing mode (category, via site.pages) ---{% endcomment %}
  {% assign prefix = page.path | append: "/" %}
  <article class="article-container docs" id="docs-container">
    {% assign found = false %}
    {% assign sorted = site.pages | order_by: '-created_at' | limit: 100 %}
    {% for item in sorted %}
      {% if item.path != page.path and item.path contains prefix and item.settings.pinned %}
        {% assign found = true %}
        <div class="docs-body docs-fixed">
          <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
          <p class="docs-p">{{ item.settings.description }}</p>
          <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
        </div>
      {% endif %}
    {% endfor %}
    {% for item in sorted %}
      {% if item.path != page.path and item.path contains prefix and item.settings.pinned == blank %}
        {% assign found = true %}
        <div class="docs-body">
          <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
          <p class="docs-p">{{ item.settings.description }}</p>
          <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
        </div>
      {% endif %}
    {% endfor %}
    {% unless found %}
      <div class="docs-body"><p class="docs-p">暂无文章</p></div>
    {% endunless %}
    {% render 'article_list_tail' %}
  </article>
{% elsif page.children.size > 0 %}
  {% comment %}--- Article listing mode (via page.children) ---{% endcomment %}
  {% assign sorted = page.children | sort: "published_at" | reverse %}
  <article class="article-container docs" id="docs-container">
    {% for item in sorted %}
      {% if item.settings.pinned %}
        <div class="docs-body docs-fixed">
          <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
          <p class="docs-p">{{ item.settings.description }}</p>
          <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
        </div>
      {% endif %}
    {% endfor %}
    {% for item in sorted %}
      {% if item.settings.pinned == blank %}
        <div class="docs-body">
          <a href="{{ item.path }}" class="docs-a"><h2 class="docs-h">{{ item.link_text }}</h2></a>
          <p class="docs-p">{{ item.settings.description }}</p>
          <time class="docs-t">{{ item.seo_description | default: item.settings.date }}</time>
        </div>
      {% endif %}
    {% endfor %}
    {% render 'article_list_tail' %}
  </article>
{% elsif is_moment %}
  {% comment %}--- Moment detail mode ---{% endcomment %}
  {% assign moment_id = page.slug | default: page.id %}
  {% assign moment_cdn_prefix = site.settings.cdn_url_prefix | strip %}
  {% if moment_cdn_prefix != blank %}
    {% unless moment_cdn_prefix contains '://' %}
      {% assign moment_cdn_prefix = 'https://' | append: moment_cdn_prefix %}
    {% endunless %}
    {% assign moment_cdn_last_char = moment_cdn_prefix | slice: -1, 1 %}
    {% if moment_cdn_last_char == '/' %}
      {% assign moment_cdn_prefix_size = moment_cdn_prefix | size | minus: 1 %}
      {% assign moment_cdn_prefix = moment_cdn_prefix | slice: 0, moment_cdn_prefix_size %}
    {% endif %}
  {% endif %}
  {% assign moment_avatar_local_url = 'images/reashal.svg' | asset_url %}
  {% assign moment_avatar_url = moment_avatar_local_url %}
  {% if moment_cdn_prefix != blank %}
    {% assign moment_avatar_url = moment_cdn_prefix | append: '/images/reashal.svg' %}
  {% endif %}
  <article class="article-container">
    <section class="moments">
      <article class="moment" id="{{ moment_id }}">
        <header class="moment-author">
          <figure class="author-avatar"><img src="{{ moment_avatar_url }}" alt="睿屿青衫" loading="lazy" decoding="async" class="view-none"{% if moment_cdn_prefix != blank %} onerror="this.onerror=null;this.src='{{ moment_avatar_local_url }}';"{% endif %} /></figure>
          <div class="author-info">
            <span class="author-name">睿屿青衫</span>
            <time class="author-date" datetime="{{ page.settings.date }}">{{ page.settings.date }}</time>
          </div>
        </header>
        {% assign moment_content = page.settings.content | default: page.content %}
        {% assign moment_content = moment_content | replace: '<div bke-role="paragraph">', '<p>' | replace: '</div>', '</p>' %}
        {% if moment_content != blank %}<section class="moment-content">{{ moment_content }}</section>{% endif %}
        {% if page.settings.images != blank %}
          {% assign img_lines = page.settings.images | newline_to_br | strip_newlines | split: "<br />" %}
          {% assign moment_image_count = 0 %}
          {% for img_line in img_lines %}
            {% assign image_parts = img_line | split: '|' %}
            {% assign moment_image_path = image_parts[0] | strip %}
            {% if moment_image_path != blank %}
              {% assign moment_image_count = moment_image_count | plus: 1 %}
            {% endif %}
          {% endfor %}
          <section class="moment-images" data-moment-id="{{ moment_id }}">
            {% if moment_image_count == 1 %}
              <figure class="img-single">
            {% elsif moment_image_count <= 4 %}
              <figure class="img-grid img-grid-2x2">
            {% else %}
              <figure class="img-grid img-grid-3x3">
            {% endif %}
            {% assign moment_image_index = 0 %}
            {% for img_line in img_lines %}
              {% assign image_parts = img_line | split: '|' %}
              {% assign moment_image_path = image_parts[0] | strip %}
              {% if moment_image_path != blank %}
                {% assign moment_image_index = moment_image_index | plus: 1 %}
                {% assign moment_image_local_url = moment_image_path %}
                {% assign moment_image_url = moment_image_path %}
                {% assign moment_image_uses_cdn = false %}
                {% unless moment_image_path contains '://' %}
                  {% assign moment_image_local_url = moment_image_path | asset_url %}
                  {% assign moment_image_url = moment_image_local_url %}
                  {% if moment_cdn_prefix != blank %}
                    {% assign moment_image_first_char = moment_image_path | slice: 0, 1 %}
                    {% if moment_image_first_char == '/' %}
                      {% assign moment_image_url = moment_cdn_prefix | append: moment_image_path %}
                    {% else %}
                      {% assign moment_image_url = moment_cdn_prefix | append: '/' | append: moment_image_path %}
                    {% endif %}
                    {% assign moment_image_uses_cdn = true %}
                  {% endif %}
                {% endunless %}
                <span hidden class="image-viewer-item" data-image-url="{{ moment_image_url | escape }}" data-local-url="{{ moment_image_local_url | escape }}" data-image-alt="{{ image_parts[1] | strip | escape }}"></span>
                {% if moment_image_count > 9 and moment_image_index == 9 %}
                  <div class="img-mask-overlay" style="background-image: url(&quot;{{ moment_image_url | escape }}&quot;){% if moment_image_uses_cdn %}, url(&quot;{{ moment_image_local_url | escape }}&quot;){% endif %};" data-image-url="{{ moment_image_url | escape }}" data-local-url="{{ moment_image_local_url | escape }}">
                    <span class="img-mask-count">+{{ moment_image_count | minus: 8 }}</span>
                  </div>
                {% elsif moment_image_count <= 9 or moment_image_index <= 8 %}
                  <img src="{{ moment_image_url }}" alt="{{ image_parts[1] | strip | escape }}" loading="lazy" decoding="async"{% if moment_image_uses_cdn %} data-local-src="{{ moment_image_local_url | escape }}" onerror="this.onerror=null;this.src=this.dataset.localSrc;"{% endif %} />
                {% endif %}
              {% endif %}
            {% endfor %}
            </figure>
          </section>
        {% endif %}
        {% if page.settings.location != blank %}<div class="moment-location"><p><code>{{ page.settings.location }}</code></p></div>{% endif %}
        {% if page.settings.stars != blank or page.settings.comments != blank %}
          <section class="moment-interaction">
            {% if page.settings.stars != blank %}
              {% assign star_list = page.settings.stars | split: "," %}
              <div class="interaction-stars">{% for star in star_list %}{% assign star_name = star | strip %}{% if star_name != blank %}<span class="star-item">{{ star_name }}</span>{% endif %}{% endfor %}</div>
            {% endif %}
            {% if page.settings.comments != blank %}
              {% assign comment_list = page.settings.comments | newline_to_br | strip_newlines | split: "<br />" %}
              <div class="interaction-comments">
                {% for comment in comment_list %}{% assign c = comment | strip %}{% if c != blank %}<p class="comment-item"><span class="comment-author">睿屿青衫:</span><span class="comment-text">{{ c }}</span></p>{% endif %}{% endfor %}
              </div>
            {% endif %}
          </section>
        {% endif %}
      </article>
      <footer class="moments-footer"><p class="end-tip">故事暂且讲到这里</p></footer>
    </section>
  </article>
{% else %}
  {% comment %}--- Standard article detail mode ---{% endcomment %}
  {% assign article_cdn_prefix = site.settings.cdn_url_prefix | strip %}
  {% if article_cdn_prefix != blank %}
    {% unless article_cdn_prefix contains '://' %}
      {% assign article_cdn_prefix = 'https://' | append: article_cdn_prefix %}
    {% endunless %}
    {% assign article_cdn_last_char = article_cdn_prefix | slice: -1, 1 %}
    {% if article_cdn_last_char == '/' %}
      {% assign article_cdn_prefix_size = article_cdn_prefix | size | minus: 1 %}
      {% assign article_cdn_prefix = article_cdn_prefix | slice: 0, article_cdn_prefix_size %}
    {% endif %}
  {% endif %}
  <article class="article-container doc">
    {% assign doc_content = page.settings.content | default: page.content %}
    {% if article_cdn_prefix != blank %}
      {% assign article_docs_cdn_url = article_cdn_prefix | append: '/images/docs/' %}
      {% assign article_cdn_prefix_size = article_cdn_prefix | size %}
      {% capture article_docs_src_double %}data-cdn-prefix-size="{{ article_cdn_prefix_size }}" onerror="this.onerror=null;this.src=this.src.substring(Number(this.dataset.cdnPrefixSize));" src="{{ article_docs_cdn_url }}{% endcapture %}
      {% capture article_docs_src_single %}data-cdn-prefix-size="{{ article_cdn_prefix_size }}" onerror="this.onerror=null;this.src=this.src.substring(Number(this.dataset.cdnPrefixSize));" src='{{ article_docs_cdn_url }}{% endcapture %}
      {% assign doc_content = doc_content | replace: 'src="/images/docs/', article_docs_src_double | replace: "src='/images/docs/", article_docs_src_single %}
    {% endif %}
    {% assign doc_content = doc_content | replace: '<div bke-role="paragraph">', '<p>' | replace: '</div>', '</p>' %}
    {{ doc_content }}
    {% assign article_tags = page.settings.tags %}
    {% if article_tags != blank %}
      <section class="article-tags">
        {% for tag in article_tags %}
          <span class="tag">{{ tag.name }}</span>
        {% endfor %}
      </section>
    {% elsif page.seo_keywords != blank %}
      {% assign kw_tags = page.seo_keywords | split: "," %}
      <section class="article-tags">
        {% for kw in kw_tags %}
          {% assign keyword_tag = kw | strip %}
          {% if keyword_tag != blank %}<span class="tag">{{ keyword_tag }}</span>{% endif %}
        {% endfor %}
      </section>
    {% endif %}
    {% assign article_source_url = page.url | default: page.path %}
    <section class="article-copy">
      <div>本文作者：<a href="{{ article_source_url }}" target="_blank" rel="noopener noreferrer">睿屿青衫</a></div>
      <div>本文来源：<a href="{{ article_source_url }}" target="_blank" rel="noopener noreferrer">{{ article_source_url }}</a></div>
      <div class="article-copy-info">许可协议：<a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0</a></div>
      <div class="article-copy-info">本站随笔均为原创，涉及隐私且时效性较强，不允许任何人以任何形式转载。</div>
      <div class="article-copy-info">本站笔记多对原始作品作出修改，允许非商业用途转载，转载时请注明出处。</div>
    </section>
    {% render 'giscus' %}
  </article>
{% endif %}

{% schema %}
  {
    "name": "随笔",
    "description": "随笔与标准页面（自动判断列表/详情模式）",
    "settings": [
      { "id": "title", "type": "text", "label": "页面标题" },
      { "id": "pinned", "type": "checkbox", "label": "置顶文章", "default": false, "info": "开启后该文章将在列表最前显示" },
      { "id": "description", "type": "textarea", "label": "页面描述" },
      { "id": "date", "type": "text", "label": "发表日期", "queryable": true },
      { "id": "images", "type": "textarea", "label": "动态图片（每行：URL|alt）" },
      { "id": "location", "type": "text", "label": "动态位置" },
      { "id": "stars", "type": "text", "label": "动态点赞（逗号分隔）" },
      { "id": "comments", "type": "textarea", "label": "动态评论（每行一条）" },
      { "id": "content", "type": "richtext", "label": "正文内容" },
      { "id": "tags", "type": "tag_picker", "multiple": true, "label": "标签" }
    ]
  }
{% endschema %}
