<article class="article-container">
  <section class="moments">
    {% assign moments_sorted = site.pages | sort: "settings.date" | reverse %}
    {% assign has = false %}
    {% for p in moments_sorted %}
      {% if p.settings.date != blank %}{% assign has = true %}{% endif %}
    {% endfor %}
    {% if has %}
      {% for p in moments_sorted %}
        {% if p.settings.date != blank %}
      <article class="moment" id="{{ p.hashid | default: p.id }}">
        <header class="moment-author">
          <figure class="author-avatar">
            <img src="{{ 'images/reashal.svg' | asset_url }}" alt="睿屿青衫" loading="lazy" decoding="async" class="view-none" />
          </figure>
          <div class="author-info">
            <span class="author-name">睿屿青衫</span>
            <time class="author-date" datetime="{{ p.settings.date }}">{{ p.settings.date }}</time>
          </div>
        </header>
        <section class="moment-content">
          <a href="{{ p.full_path }}">{{ p.link_text }}</a>
        </section>
        {% if p.content != blank %}
          <section class="moment-content">{{ p.content }}</section>
        {% endif %}
        {% if p.settings.images != blank %}
          {% assign img_lines = p.settings.images | newline_to_br | strip_newlines | split: "<br />" %}
          <section class="moment-images">
            {% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}<img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" />{% endfor %}
          </section>
        {% endif %}
        {% if p.settings.location != blank %}
          <div class="moment-location"><code>{{ p.settings.location }}</code></div>
        {% endif %}
        {% if p.settings.stars != blank or p.settings.comments != blank %}
          <section class="moment-interaction">
            {% if p.settings.stars != blank %}
              {% assign star_list = p.settings.stars | split: "," %}
              <div class="interaction-stars">{% for star in star_list %}<span class="star-item">{{ star | strip }}</span>{% endfor %}</div>
            {% endif %}
            {% if p.settings.comments != blank %}
              {% assign comment_list = p.settings.comments | newline_to_br | strip_newlines | split: "<br />" %}
              <div class="interaction-comments">
                {% for comment in comment_list %}{% assign c = comment | strip %}{% if c != blank %}<p class="comment-item"><span class="comment-author">睿屿青衫:</span><span class="comment-text">{{ c }}</span></p>{% endif %}{% endfor %}
              </div>
            {% endif %}
          </section>
        {% endif %}
      </article>
        {% endif %}
      {% endfor %}
    {% else %}
      <p style="text-align:center;color:#999;padding:2rem;">暂无动态</p>
    {% endif %}
    <footer class="moments-footer">
      <p class="end-tip">故事暂且讲到这里</p>
    </footer>
  </section>
</article>

{% schema %}
  {
    "name": "首页",
    "description": "动态流首页",
    "thumb_url": "",
    "sub_page_templates": ["page"],
    "settings": []
  }
{% endschema %}
