<article class="article-container">
  <section class="moments">
    <h1>{{ site.settings.index_title | default: '动态' }}</h1>
    {% assign moments_cdn_prefix = site.settings.cdn_url_prefix | strip %}
    {% if moments_cdn_prefix != blank %}
      {% unless moments_cdn_prefix contains '://' %}
        {% assign moments_cdn_prefix = 'https://' | append: moments_cdn_prefix %}
      {% endunless %}
      {% assign moments_cdn_last_char = moments_cdn_prefix | slice: -1, 1 %}
      {% if moments_cdn_last_char == '/' %}
        {% assign moments_cdn_prefix_size = moments_cdn_prefix | size | minus: 1 %}
        {% assign moments_cdn_prefix = moments_cdn_prefix | slice: 0, moments_cdn_prefix_size %}
      {% endif %}
    {% endif %}
    {% assign moment_avatar_local_url = 'images/reashal.svg' | asset_url %}
    {% assign moment_avatar_url = moment_avatar_local_url %}
    {% if moments_cdn_prefix != blank %}
      {% assign moment_avatar_url = moments_cdn_prefix | append: '/images/reashal.svg' %}
    {% endif %}
    {% query moment_pages from page.children %}
      {
        "where": {
          "template_name_eq": "page",
          "template_style_eq": "moment"
        }
      }
    {% endquery %}
    {% assign moment_pages = moment_pages | order_by: '-created_at' %}
    {% paginate_tag moment_pages, as: 'paginated_moments', per: 3 %}
    {% assign has = false %}
    {% for p in paginated_moments %}
      {% assign has = true %}
      {% render 'moment_card', p: p, moments_cdn_prefix: moments_cdn_prefix, moment_avatar_url: moment_avatar_url, moment_avatar_local_url: moment_avatar_local_url %}
    {% endfor %}
    {% unless has %}
      <p style="text-align:center;color:#999;padding:2rem;">暂无动态</p>
    {% endunless %}
    {% assign moments_next_url = blank %}
    {% if paginate.next_page %}
      {% assign moments_next_url = paginate.url_for[paginate.next_page] %}
    {% endif %}
    <footer class="moments-footer">
      <p class="end-tip" data-moments-status>{% if moments_next_url != blank %}继续下滑{% else %}故事暂且讲到这里{% endif %}</p>
      <div id="moments-pagination" aria-hidden="true" style="height:1px;overflow:hidden;" data-next-url="{{ moments_next_url | escape }}" data-page-size="3"></div>
    </footer>
    {% endpaginate_tag %}
  </section>
</article>

{% schema %}
  {
    "name": "动态流",
    "description": "动态流首页",
    "thumb_url": "",
    "sub_page_templates": ["page"],
    "settings": []
  }
{% endschema %}
