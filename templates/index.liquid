<article class="article-container">
  <section class="moments">
    <p>Page ID: {{ page.id }}</p>
    <p>Page path: {{ page.full_path }}</p>

    {% assign c1 = page.children %}
    <p>children.size: {{ c1.size }}</p>

    {% assign c2 = page.children_in_list %}
    <p>children_in_list.size: {{ c2.size }}</p>

    {% assign c3 = page.children_in_nav_menu %}
    <p>children_in_nav_menu.size: {{ c3.size }}</p>

    {% assign c4 = page.pages %}
    <p>pages.size: {{ c4.size }}</p>

    {% assign c5 = page.pages_in_list %}
    <p>pages_in_list.size: {{ c5.size }}</p>

    {% assign root = site.pages['/'] %}
    {% if root %}
      <p>Root found: {{ root.id }} {{ root.link_text }}</p>
      {% assign rc = root.children %}
      <p>root.children.size: {{ rc.size }}</p>
    {% else %}
      <p>Root NOT found</p>
    {% endif %}

    <h3>Debug: site.pages_in_list limit 5</h3>
    {% assign all = site.pages_in_list | limit: 5 %}
    <p>site.pages_in_list: {{ all.size }} items</p>
    {% for p in all %}
      <p>- {{ p.id }} {{ p.link_text }} | {{ p.full_path }} | t:{{ p.template_name }}</p>
    {% endfor %}
  </section>
</article>

{% schema %}
  {
    "name": "首页",
    "description": "动态流首页",
    "thumb_url": "",
    "sub_page_templates": ["page"],
    "settings": []
  }
{% endschema %}
