<article class="article-container">
    <section class="moments">
            <h1>动态</h1>
    {% assign has = false %}
    {% for p in site.pages %}
      {% if p.settings.date != blank %}{% assign has = true %}{% endif %}
    {% endfor %}
    {% if has %}
      {% for p in site.pages reversed %}
        {% if p.settings.date != blank %}
      <article class="moment" id="{{ p.hashid | default: p.id }}">
        <header class="moment-author">
          <figure class="author-avatar">
            <img src="{{ 'images/reashal.svg' | asset_url }}" alt="睿屿青衫" loading="lazy" decoding="async" class="view-none" />
          </figure>
          <div class="author-info">
            <span class="author-name">睿屿青衫</span>
            <time class="author-date" datetime="{{ p.settings.date }}">{{ p.settings.date }}</time>
          </div>
        </header>
        <section class="moment-content">
          <a href="{{ p.full_path }}">{{ p.link_text }}</a>
          {% if p.content != blank %}{{ p.content }}{% endif %}
        </section>
        {% if p.settings.images != blank %}
          {% assign img_lines = p.settings.images | newline_to_br | strip_newlines | split: "<br />" %}
          {% assign img_count = img_lines | size %}
          {% assign moment_date_key = p.settings.date | remove: "." %}
          {% assign imgs_json = "[" %}
          {% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}{% assign url = img_parts[0] | strip | asset_url %}{% assign alt = img_parts[1] | strip %}{% assign imgs_json = imgs_json | append: '{"url":"' | append: url | append: '","alt":"' | append: alt | append: '"}' %}{% unless forloop.last %}{% assign imgs_json = imgs_json | append: "," %}{% endunless %}{% endfor %}
          {% assign imgs_json = imgs_json | append: "]" %}
          <section class="moment-images" data-moment-id="{{ moment_date_key }}" data-imgs='{{ imgs_json }}'>
            {% if img_count == 1 %}
              {% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}<figure class="img-single"><img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" /></figure>{% endfor %}
            {% elsif img_count <= 4 %}
              <figure class="img-grid img-grid-2x2">{% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}<img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" />{% endfor %}</figure>
            {% elsif img_count <= 9 %}
              <figure class="img-grid img-grid-3x3">{% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}<img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" />{% endfor %}</figure>
            {% else %}
              <figure class="img-grid img-grid-3x3">{% for img_line in img_lines limit:8 %}{% assign img_parts = img_line | split: "|" %}<img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" />{% endfor %}{% assign img_p9 = img_lines[8] | split: "|" %}<div class="img-mask-overlay" style="background-image: url('{{ img_p9[0] | strip | asset_url }}')"><span class="img-mask-count">+{{ img_count | minus: 8 }}</span></div></figure>
            {% endif %}
          </section>
        {% endif %}
        {% if p.settings.location != blank %}
          <div class="moment-location"><p><code>{{ p.settings.location }}</code></p></div>
        {% endif %}
        {% if p.settings.stars != blank or p.settings.comments != blank %}
          <section class="moment-interaction">
            {% if p.settings.stars != blank %}
              {% assign star_list = p.settings.stars | split: "," %}
              <div class="interaction-stars">{% for star in star_list %}<span class="star-item">{{ star | strip }}</span>{% endfor %}</div>
            {% endif %}
            {% if p.settings.comments != blank %}
              {% assign comment_list = p.settings.comments | newline_to_br | strip_newlines | split: "<br />" %}
              <div class="interaction-comments">
                {% for comment in comment_list %}{% assign c = comment | strip %}{% if c != blank %}<p class="comment-item"><span class="comment-author">睿屿青衫:</span><span class="comment-text">{{ c }}</span></p>{% endif %}{% endfor %}
              </div>
            {% endif %}
          </section>
        {% endif %}
      </article>
        {% endif %}
      {% endfor %}
    {% else %}
      <p style="text-align:center;color:#999;padding:2rem;">暂无动态</p>
    {% endif %}
    <footer class="moments-footer">
      <p class="end-tip">故事暂且讲到这里</p>
    </footer>
  </section>
</article>

{% schema %}
  {
    "name": "首页",
    "description": "动态流首页",
    "thumb_url": "",
    "sub_page_templates": ["page"],
    "settings": []
  }
{% endschema %}
