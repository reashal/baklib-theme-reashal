<article class="article-container docs" id="docs-container">
  {% assign tag_param = params.tag %}
  {% assign q_param = params.q %}
  {% assign tag_name = search.tag.name | default: search.tag | default: tag_param %}
  {% assign kw = search.keywords | default: q_param %}
  <h1>{{ tag_name | default: kw | default: '搜索' }}</h1>
  {% form_tag 'search' %}
    <input type="search" name="{{ form.keywords_field_name }}" value="{{ kw | escape_once }}" placeholder="搜索..." />
  {% endform_tag %}

  {% assign found = false %}
  {% assign all_pages = site.pages | where: 'template_name', 'page' %}
  {% for page in all_pages %}
    {% assign match = false %}
    {% if tag_name and page.seo_keywords != blank and page.seo_keywords contains tag_name %}
      {% assign match = true %}
    {% elsif kw %}
      {% assign kw_lower = kw | downcase %}
      {% assign haystacks = page.link_text | append: ' ' | append: page.settings.title | append: ' ' | append: page.seo_keywords | append: ' ' | append: page.settings.description | downcase %}
      {% if haystacks contains kw_lower %}
        {% assign match = true %}
      {% endif %}
    {% endif %}
    {% if match %}
      {% assign found = true %}
      <div class="docs-body">
        <a href="{{ page.path }}" class="docs-a"><h2 class="docs-h">{{ page.link_text }}</h2></a>
        <p class="docs-p">{{ page.settings.description }}</p>
        <time class="docs-t">{{ page.published_at | date: "%Y-%m-%d" }}</time>
      </div>
    {% endif %}
  {% endfor %}
  {% if found == false %}
    <div class="docs-body"><p class="docs-p">未找到结果</p></div>
  {% endif %}
</article>

{% schema %}
  {
    "name": "搜索",
    "description": "站点搜索页",
    "settings": []
  }
{% endschema %}
