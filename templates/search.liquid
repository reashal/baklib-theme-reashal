<div class="article-container docs">
  <h1>{{ search.tag.name | default: search.tag | default: '搜索' }}</h1>
  {% form_tag 'search' %}
    <input type="search" name="{{ form.keywords_field_name }}" value="{{ search.keywords | escape_once }}" placeholder="搜索..." />
  {% endform_tag %}

  {% assign tag_name = search.tag.name | default: search.tag %}
  {% assign found = false %}
  {% assign all_pages = site.pages | where: 'template_name', 'page' %}
  {% for page in all_pages %}
    {% assign match = false %}
    {% if tag_name and page.seo_keywords != blank and page.seo_keywords contains tag_name %}
      {% assign match = true %}
    {% elsif search.keywords %}
      {% assign kw = search.keywords | downcase %}
      {% assign haystacks = page.link_text | append: ' ' | append: page.settings.title | append: ' ' | append: page.seo_keywords | append: ' ' | append: page.settings.description | downcase %}
      {% if haystacks contains kw %}
        {% assign match = true %}
      {% endif %}
    {% endif %}
    {% if match %}
      {% assign found = true %}
      <div class="docs-body">
        <a href="{{ page.path }}"><h2 class="docs-h">{{ page.link_text }}</h2></a>
        <p class="docs-p">{{ page.settings.description }}</p>
      </div>
    {% endif %}
  {% endfor %}
  {% if found == false %}
    <p>未找到结果</p>
  {% endif %}
</div>

{% schema %}
  {
    "name": "搜索",
    "description": "站点搜索页",
    "settings": []
  }
{% endschema %}
