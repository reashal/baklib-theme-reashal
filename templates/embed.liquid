{% layout false %}
<!DOCTYPE html>
<html lang="{{ site.language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
  <title>动态｜睿屿青衫</title>
  <style>
    html,body{margin:0;padding:0;width:100%;height:100%;overflow:auto}
    body{background-color:#fff;font-family:"HM";padding:20px}
    .dark body{background-color:rgb(17,24,38)}
  </style>
  {{ 'stylesheets/application.css' | asset_url | stylesheet_tag }}
  {{ 'stylesheets/reashal-base.css' | asset_url | stylesheet_tag }}
  {{ 'stylesheets/reashal-moments.css' | asset_url | stylesheet_tag }}
  {{ 'stylesheets/iconfont.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <section class="moments">
            <h1>动态</h1>
    {% for moment in site.pages reversed %}{% if moment.settings.date != blank %}
      {% assign moment_id = moment.slug | default: moment.hashid %}
      <article class="moment" id="{{ moment_id }}">
        <header class="moment-author">
          <figure class="author-avatar"><img src="{{ 'images/reashal.svg' | asset_url }}" alt="睿屿青衫" loading="lazy" decoding="async" class="view-none" /></figure>
          <div class="author-info">
            <span class="author-name">睿屿青衫</span>
            <time class="author-date" datetime="{{ moment.settings.date }}">{{ moment.settings.date }}</time>
          </div>
        </header>
        {% if moment.content != blank %}<section class="moment-content">{{ moment.content }}</section>{% endif %}
        {% if moment.settings.images != blank %}
          {% assign img_lines = moment.settings.images | newline_to_br | strip_newlines | split: "<br />" %}
          {% assign img_count = img_lines | size %}
          {% assign moment_date_key = moment.settings.date | remove: "." %}
          {% assign imgs_json = "[" %}
          {% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}{% assign url = img_parts[0] | strip | asset_url %}{% assign alt = img_parts[1] | strip %}{% assign imgs_json = imgs_json | append: '{"url":"' | append: url | append: '","alt":"' | append: alt | append: '"}' %}{% unless forloop.last %}{% assign imgs_json = imgs_json | append: "," %}{% endunless %}{% endfor %}
          {% assign imgs_json = imgs_json | append: "]" %}
          <section class="moment-images" data-moment-id="{{ moment_date_key }}" data-imgs='{{ imgs_json }}'>
            {% if img_count == 1 %}
              {% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}<figure class="img-single"><img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" /></figure>{% endfor %}
            {% elsif img_count <= 4 %}
              <figure class="img-grid img-grid-2x2">{% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}<img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" />{% endfor %}</figure>
            {% elsif img_count <= 9 %}
              <figure class="img-grid img-grid-3x3">{% for img_line in img_lines %}{% assign img_parts = img_line | split: "|" %}<img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" />{% endfor %}</figure>
            {% else %}
              <figure class="img-grid img-grid-3x3">{% for img_line in img_lines limit:8 %}{% assign img_parts = img_line | split: "|" %}<img src="{{ img_parts[0] | strip | asset_url }}" alt="{{ img_parts[1] | strip }}" loading="lazy" decoding="async" class="view-none" />{% endfor %}{% assign img_p9 = img_lines[8] | split: "|" %}<div class="img-mask-overlay" style="background-image: url('{{ img_p9[0] | strip | asset_url }}')"><span class="img-mask-count">+{{ img_count | minus: 8 }}</span></div></figure>
            {% endif %}
          </section>
        {% endif %}
        {% if moment.settings.location != blank %}<div class="moment-location"><p><code>{{ moment.settings.location }}</code></p></div>{% endif %}
      </article>
    {% endif %}{% endfor %}
    <footer class="moments-footer"><p class="end-tip">故事暂且讲到这里</p></footer>
  </section>
  <script>
    (function(){var h=new Date().getHours();if(h>20||h<6||window.matchMedia("(prefers-color-scheme:dark)").matches)document.documentElement.classList.add("dark");})();
  </script>
</body>
</html>

{% schema %}
  {
    "name": "嵌入版动态",
    "description": "用于 iframe 嵌入的简化动态页",
    "settings": []
  }
{% endschema %}
