
{% assign moment_id = page.slug | default: page.hashid %}
<article class="article-container">
  <section class="moments">
    <article class="moment" id="{{ moment_id }}">
      <header class="moment-author">
        <figure class="author-avatar"><img src="{{ 'images/reashal.svg' | asset_url }}" alt="睿屿青衫" loading="lazy" decoding="async" class="view-none" /></figure>
        <div class="author-info">
          <span class="author-name">睿屿青衫</span>
          <time class="author-date" datetime="{{ page.settings.date }}">{{ page.settings.date }}</time>
        </div>
      </header>
      {% assign moment_content = page.settings.content | default: page.content %}
      {% assign moment_content = moment_content | replace: '<div bke-role="paragraph">', '<p>' | replace: '</div>', '</p>' %}
      {% if moment_content != blank %}<section class="moment-content">{{ moment_content }}</section>{% endif %}
      {% if page.settings.images != blank %}
        {% assign img_lines = page.settings.images | newline_to_br | strip_newlines | split: "<br />" %}
        <section class="moment-images">
          {% for img_line in img_lines %}{% assign p = img_line | split: "|" %}<img src="{{ p[0] | strip | asset_url }}" alt="{{ p[1] | strip }}" loading="lazy" decoding="async" />{% endfor %}
        </section>
      {% endif %}
      {% if page.settings.location != blank %}<div class="moment-location"><p><code>{{ page.settings.location }}</code></p></div>{% endif %}
      {% if page.settings.stars != blank or page.settings.comments != blank %}
        <section class="moment-interaction">
          {% if page.settings.stars != blank %}
            {% assign star_list = page.settings.stars | split: "," %}
            <div class="interaction-stars">{% for star in star_list %}<span class="star-item">{{ star | strip }}</span>{% endfor %}</div>
          {% endif %}
          {% if page.settings.comments != blank %}
            {% assign comment_list = page.settings.comments | newline_to_br | strip_newlines | split: "<br />" %}
            <div class="interaction-comments">
              {% for comment in comment_list %}{% assign c = comment | strip %}{% if c != blank %}<p class="comment-item"><span class="comment-author">睿屿青衫:</span><span class="comment-text">{{ c }}</span></p>{% endif %}{% endfor %}
            </div>
          {% endif %}
        </section>
      {% endif %}
    </article>
    <footer class="moments-footer"><p class="end-tip">故事暂且讲到这里</p></footer>
  </section>
</article>

{% schema %}
  {
    "name": "动态",
    "description": "动态详情页",
    "settings": [
      { "id": "date", "type": "text", "label": "发表日期", "queryable": true },
      { "id": "images", "type": "textarea", "label": "动态图片（每行：URL|alt）" },
      { "id": "location", "type": "text", "label": "动态位置" },
      { "id": "stars", "type": "text", "label": "动态点赞（逗号分隔）" },
      { "id": "comments", "type": "textarea", "label": "动态评论（每行一条）" },
      { "id": "content", "type": "richtext", "label": "正文内容" }
    ],
    "user_creatable": true,
    "user_editable": true,
    "user_deletable": true,
    "user_permitted_attributes": ["date", "images", "location", "stars", "comments", "content"]
  }
{% endschema %}
